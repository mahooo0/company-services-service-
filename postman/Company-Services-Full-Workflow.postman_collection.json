    {
      "name": "3. Upload Image (Storage)",
      "item": [
        {
          "name": "Upload Avatar Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Image uploaded', function () {",
                  "    var status = pm.response.code;",
                  "    if (status === 200 || status === 201) {",
                  "        var json = pm.response.json();",
                  "        if (json.id) pm.collectionVariables.set('imageId', json.id);",
                  "        if (json.url) console.log('Image URL:', json.url);",
                  "    } else {",
                  "        console.log('Storage service response:', pm.response.code, pm.response.text());",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Выберите изображение для загрузки"
                },
                {
                  "key": "folder",
                  "value": "avatars",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{storageUrl}}/upload",
              "host": ["{{storageUrl}}"],
              "path": ["upload"]
            }
          }
        }
      ]
    },
