                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('categoryId', json.id);",
                  "    console.log('categoryId saved:', json.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Красота и здоровье\",\n  \"slug\": \"beauty-health\"\n}"
            },
