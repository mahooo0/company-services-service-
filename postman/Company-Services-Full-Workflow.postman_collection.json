{
  "info": {
    "_postman_id": "company-services-full-workflow",
    "name": "Company Services - Full Workflow (Deployment)",
    "description": "Полный workflow тестирования company-services-service на deployment.\n\nПорядок:\n1. Health Check\n2. Создать категорию\n3. Создать тип услуги\n4. Загрузить изображение (storage)\n5. Создать услугу\n6. Создать специалиста\n7. Привязать услугу к специалисту\n8. Привязать локацию к специалисту\n9. Привязать услугу к локации\n10. Создать расписание\n11. Bulk обновление расписания\n12. Запросы: специалисты/услуги по локации, расписание\n\nВсе ID автоматически сохраняются в переменные.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayUrl", "value": "https://gateway.4friends.in.ua", "type": "string" },
    { "key": "directUrl", "value": "http://5.189.161.29:3017", "type": "string" },
    { "key": "storageUrl", "value": "https://gateway.4friends.in.ua/api/v1/storage", "type": "string" },
    { "key": "baseUrl", "value": "https://gateway.4friends.in.ua/api/v1", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "organizationId", "value": "00000000-0000-0000-0000-000000000001", "type": "string" },
    { "key": "locationId", "value": "00000000-0000-0000-0000-000000000010", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" },
    { "key": "serviceTypeId", "value": "", "type": "string" },
    { "key": "serviceId", "value": "", "type": "string" },
    { "key": "specialistId", "value": "", "type": "string" },
    { "key": "scheduleId", "value": "", "type": "string" },
    { "key": "imageId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "0. Health & Setup",
      "item": [
        {
          "name": "Health Check (direct)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Service is healthy', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{directUrl}}/health",
              "host": ["{{directUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Health Check (via gateway)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Gateway может не иметь health route, проверяем что сервис доступен",
                  "pm.test('Gateway reachable', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/service-categories",
              "host": ["{{baseUrl}}"],
              "path": ["service-categories"]
            }
          }
        }
      ]
    },
