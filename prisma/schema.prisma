// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Категории типов услуг (vetClinicsFilter, groomingFilter, etc.)
model ServiceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  types ServiceType[]

  @@map("service_categories")
}

// Типы услуг
model ServiceType {
  id                String            @id @default(uuid())
  name              String
  slug              String            @unique
  categoryId        String
  status            ServiceTypeStatus @default(ACTIVE)
  suggestedByUserId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  services Service[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("service_types")
}

enum ServiceTypeStatus {
  ACTIVE
  PENDING
  REJECTED
}

// Услуги
model Service {
  id             String   @id @default(uuid())
  organizationId String
  branchId       String?
  name           String
  description    String?
  typeId         String
  price          Decimal? @db.Decimal(10, 2)
  imageId        String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  type               ServiceType          @relation(fields: [typeId], references: [id])
  variations         ServiceVariation[]
  specialistServices SpecialistService[]
  locationServices   LocationService[]

  @@index([organizationId])
  @@index([organizationId, sortOrder])
  @@index([branchId])
  @@index([typeId])
  @@map("services")
}

// Вариации услуг
model ServiceVariation {
  id        String   @id @default(uuid())
  serviceId String
  name      String
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_variations")
}

// Специалисты
model Specialist {
  id             String   @id @default(uuid())
  organizationId String
  avatar         String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  description    String?
  isTopMaster    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  services  SpecialistService[]
  locations SpecialistLocation[]
  schedules Schedule[]

  @@index([organizationId])
  @@map("specialists")
}

// Связь: Специалист <-> Услуга (many-to-many)
model SpecialistService {
  id             String   @id @default(uuid())
  specialistId   String
  serviceId      String
  organizationId String
  createdAt      DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([specialistId, serviceId])
  @@index([organizationId])
  @@index([specialistId])
  @@index([serviceId])
  @@map("specialist_services")
}

// Связь: Специалист <-> Локация (many-to-many)
model SpecialistLocation {
  id             String   @id @default(uuid())
  specialistId   String
  locationId     String
  organizationId String
  createdAt      DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@unique([specialistId, locationId])
  @@index([organizationId])
  @@index([specialistId])
  @@index([locationId])
  @@map("specialist_locations")
}

// Связь: Локация <-> Услуга (many-to-many)
model LocationService {
  id             String   @id @default(uuid())
  locationId     String
  serviceId      String
  organizationId String
  createdAt      DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([locationId, serviceId])
  @@index([organizationId])
  @@index([locationId])
  @@index([serviceId])
  @@map("location_services")
}

// Расписание специалиста в локации
model Schedule {
  id             String   @id @default(uuid())
  organizationId String
  specialistId   String
  locationId     String
  dayOfWeek      Int // 0 = Воскресенье, 1 = Понедельник, ..., 6 = Суббота
  intervals      Json     @default("[]") // [{startTime: "09:00", endTime: "17:00"}]
  isDayOff       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@unique([specialistId, locationId, dayOfWeek])
  @@index([organizationId])
  @@index([specialistId])
  @@index([locationId])
  @@map("schedules")
}
